---
// src/components/MobileHeader.astro
---

<header class="mobile-header">
  <img src="/icons/BETO.png" alt="Pizza de Verdad" class="mobile-header-logo" />
  <div class="mobile-header-right">
    <div class="mobile-user-pill">
      <span class="mobile-username">%username%</span>
      <div class="mobile-avatar"></div>
    </div>
    <button class="mobile-logout-btn" id="mobile-logout-btn" title="Cerrar sesión">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </button>
  </div>
</header>

<style>
  .mobile-header {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background-color: var(--color-primary);
      padding: 14px 20px;
      width: 100%;
      box-sizing: border-box;
    }

    .mobile-header-logo {
      width: 52px;
      height: auto;
    }

    .mobile-header-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .mobile-user-pill {
      background-color: rgba(0, 0, 0, 0.35);
      color: white;
      padding: 6px 6px 6px 14px;
      border-radius: 100px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.8rem;
      font-weight: 500;
    }

    .mobile-avatar {
      width: 30px;
      height: 30px;
      background-color: white;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* Botón cerrar sesión — junto al pill */
    .mobile-logout-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      border: none;
      border-radius: 50%;
      background-color: rgba(0, 0, 0, 0.25);
      color: white;
      cursor: pointer;
      transition: background 0.2s;
      flex-shrink: 0;
    }

    .mobile-logout-btn:hover,
    .mobile-logout-btn:active {
      background-color: rgba(0, 0, 0, 0.45);
    }
  }
</style>
